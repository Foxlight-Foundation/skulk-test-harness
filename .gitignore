.DS_Store
.env
.env.*
.venv/
__pycache__/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.basedpyright/
node_modules/
dist/
build/
logs/
runs/
tmp/
skulk-harness.yaml

# Local per-node harness configs (e.g. failover routed at a surviving node)
skulk-harness-*.yaml

# Local profile variants (e.g. skulk-harness.stability.yaml copied from examples)
skulk-harness.*.yaml

!skulk-harness.example.yaml
!examples/foxlight/skulk-harness.yaml
!examples/foxlight/skulk-harness.stability.example.yaml

# machine-local results-ledger auto-publish switches (publishing is on by
# default; .autopublish-results-off holds it on this machine; the old opt-in
# .autopublish-results marker is obsolete but kept ignored so stale copies
# do not show as untracked noise)
.autopublish-results
.autopublish-results-off
